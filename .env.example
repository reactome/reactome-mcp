# Reactome MCP Configuration
# Copy this file to .env and adjust values for your environment

# API Service URLs
CONTENT_SERVICE_URL=https://reactome.org/ContentService/
ANALYSIS_SERVICE_URL=https://reactome.org/AnalysisService/

# Request Timeouts (milliseconds)
REQUEST_TIMEOUT=15000
HEAVY_REQUEST_TIMEOUT=30000

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# Cache TTLs (seconds)
CACHE_TTL_SPECIES=3600          # 1 hour
CACHE_TTL_DISEASES=3600         # 1 hour
CACHE_TTL_DBINFO=86400          # 24 hours
CACHE_TTL_QUERIES=300           # 5 minutes

# Input Validation Limits
MAX_BATCH_IDENTIFIERS=50000
MAX_SEARCH_QUERY_LENGTH=500
MAX_PAGE_SIZE=100

# Rate Limiting (requests per minute per client)
RATE_LIMIT_ANALYSIS=10
RATE_LIMIT_SEARCH=20
RATE_LIMIT_GENERAL=30

# Logging Configuration
LOG_LEVEL=info                  # debug, info, warn, error

# Environment
NODE_ENV=development            # development or production
